#!/usr/bin/env bash
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/_functions.sh"
odh

ENV_FILE="$(pwd)/.env.local"

set -a
source "$ENV_FILE"
set +a

if ! grep -q '^DEV_IMPERSONATE_USER=' "$ENV_FILE" || ! grep -q '^DEV_IMPERSONATE_TOKEN=' "$ENV_FILE"; then
  echo "No uncommented DEV_IMPERSONATE_USER and/or DEV_IMPERSONATE_TOKEN found in .env.local. Nothing was changed." >&2
  exit 1
fi

echo "Logging in to $OC_URL via web browser..."
if ! oc login --server="$OC_URL" --web; then
  echo "Login failed." >&2
  exit 1
fi

TOKEN=$(oc whoami -t)
USER=$(oc whoami)
if [ -z "$TOKEN" ]; then
  echo "Failed to retrieve token." >&2
  exit 1
fi

awk -v token="$TOKEN" -v user="$USER" '
  { lines[NR] = $0 }
  /^DEV_IMPERSONATE_USER=/ { lastUser = NR }
  /^DEV_IMPERSONATE_TOKEN=/ { lastToken = NR }
  END {
    for (i = 1; i <= NR; i++) {
      if (i == lastUser) print "DEV_IMPERSONATE_USER=" user
      else if (i == lastToken) print "DEV_IMPERSONATE_TOKEN=" token
      else print lines[i]
    }
  }
' "$ENV_FILE" > "$ENV_FILE.tmp" && mv "$ENV_FILE.tmp" "$ENV_FILE"
echo ">>> Switching back to your original oc session..."
"$SCRIPT_DIR/odh-login"
echo
echo "------------------------------------------------------------------------------"
ENV_DISPLAY="${ENV_FILE/#$HOME/~}"
echo "Replaced DEV_IMPERSONATE_USER and DEV_IMPERSONATE_TOKEN in $ENV_DISPLAY using token for $USER."
echo "Restored shell oc login to $(oc whoami)."
