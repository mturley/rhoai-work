#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
WORKSPACE="$(dirname "$SCRIPT_DIR")"
ODH_DIR="$WORKSPACE/opendatahub-io/odh-dashboard"
ENV_FILE="$ODH_DIR/.env.local"

die() { echo "error: $*" >&2; exit 1; }

[[ -f "$ENV_FILE" ]] || die ".env.local not found at $ENV_FILE"

# ---------------------------------------------------------------------------
# Parse cluster definitions from # @cluster ... # @endcluster blocks
# Parallel arrays indexed the same way. Multi-value fields use $'\n' delimiter.
# ---------------------------------------------------------------------------
C_IDS=()
C_NAMES=()
C_USERS=()      # newline-delimited usernames
C_PASSWORDS=()  # newline-delimited passwords (parallel to C_USERS)
C_ENVS=()       # newline-delimited KEY=value lines
C_URLS=()       # newline-delimited "LABEL url" lines

parse_clusters() {
  local cur_id="" cur_name=""
  local users="" passwords="" envs="" urls=""

  while IFS= read -r line; do
    if [[ "$line" =~ ^#\ @cluster\ id=([^ ]+)\ name=\"([^\"]+)\" ]]; then
      cur_id="${BASH_REMATCH[1]}"
      cur_name="${BASH_REMATCH[2]}"
      users="" passwords="" envs="" urls=""
    elif [[ "$line" == "# @endcluster" && -n "$cur_id" ]]; then
      C_IDS+=("$cur_id")
      C_NAMES+=("$cur_name")
      C_USERS+=("$users")
      C_PASSWORDS+=("$passwords")
      C_ENVS+=("$envs")
      C_URLS+=("$urls")
      cur_id=""
    elif [[ -n "$cur_id" ]]; then
      if [[ "$line" =~ ^#\ @user\ (.+) ]]; then
        local rest="${BASH_REMATCH[1]}"
        local u p
        u="${rest%% *}"
        if [[ "$rest" == *" "* ]]; then
          p="${rest#* }"
        else
          echo "error: cluster '$cur_id' has @user '$u' with no password" >&2
          exit 1
        fi
        users+="${users:+$'\n'}$u"
        passwords+="${passwords:+$'\n'}$p"
      elif [[ "$line" =~ ^#\ @env\ (.+) ]]; then
        envs+="${envs:+$'\n'}${BASH_REMATCH[1]}"
      elif [[ "$line" =~ ^#\ @url\ (.+) ]]; then
        urls+="${urls:+$'\n'}${BASH_REMATCH[1]}"
      fi
    fi
  done < "$ENV_FILE"
}

# Find cluster index by ID, returns "" if not found
find_cluster_idx() {
  local target=$1
  for i in "${!C_IDS[@]}"; do
    if [[ "${C_IDS[$i]}" == "$target" ]]; then
      echo "$i"
      return
    fi
  done
}

get_active_id() {
  local line
  line=$(grep '^# @active' "$ENV_FILE" 2>/dev/null | head -1) || true
  if [[ "$line" =~ ^#\ @active\ id=([^ ]+) ]]; then
    echo "${BASH_REMATCH[1]}"
  fi
}

# ---------------------------------------------------------------------------
# Actions
# ---------------------------------------------------------------------------

list_clusters() {
  local active_id
  active_id=$(get_active_id)
  printf "%-14s %-35s %s\n" "ID" "NAME" "STATUS"
  printf "%-14s %-35s %s\n" "--" "----" "------"
  for i in "${!C_IDS[@]}"; do
    local id="${C_IDS[$i]}"
    local status=""
    [[ "$id" == "$active_id" ]] && status="* active"
    printf "%-14s %-35s %s\n" "$id" "${C_NAMES[$i]}" "$status"
  done
}

switch_cluster() {
  local target_id=$1
  local target_user=${2:-}

  local idx
  idx=$(find_cluster_idx "$target_id")
  [[ -n "$idx" ]] || die "unknown cluster '$target_id'. Run 'odh-env' to list available clusters."

  local target_name="${C_NAMES[$idx]}"

  # Parse users/passwords into arrays
  local -a users=() passwords=()
  if [[ -n "${C_USERS[$idx]}" ]]; then
    while IFS= read -r u; do users+=("$u"); done <<< "${C_USERS[$idx]}"
    while IFS= read -r p; do passwords+=("$p"); done <<< "${C_PASSWORDS[$idx]}"
  fi

  [[ ${#users[@]} -gt 0 ]] || die "cluster '$target_id' has no @user lines"

  # Select user
  local selected_idx=0
  if [[ -n "$target_user" ]]; then
    local found=false
    for i in "${!users[@]}"; do
      if [[ "${users[$i]}" == "$target_user" ]]; then
        selected_idx=$i; found=true; break
      fi
    done
    $found || die "user '$target_user' not found for cluster '$target_id'. Available: ${users[*]}"
  elif [[ ${#users[@]} -gt 1 ]]; then
    echo "Select user for $target_name:"
    for i in "${!users[@]}"; do
      local marker=""
      [[ $i -eq 0 ]] && marker=" (default)"
      echo "  $((i + 1))) ${users[$i]}$marker"
    done
    printf "Choice [1]: "
    read -r choice
    choice=${choice:-1}
    if [[ "$choice" -ge 1 && "$choice" -le ${#users[@]} ]] 2>/dev/null; then
      selected_idx=$((choice - 1))
    else
      die "invalid choice"
    fi
  fi

  local sel_user="${users[$selected_idx]}"
  local sel_pass="${passwords[$selected_idx]}"

  # Build the new @active block
  local active_block=""
  active_block+="# @active id=$target_id"$'\n'
  if [[ -n "${C_ENVS[$idx]}" ]]; then
    while IFS= read -r env_line; do
      [[ -n "$env_line" ]] && active_block+="$env_line"$'\n'
    done <<< "${C_ENVS[$idx]}"
  fi
  active_block+="OC_USER=$sel_user"$'\n'
  [[ -n "$sel_pass" ]] && active_block+="OC_PASSWORD=$sel_pass"$'\n'
  active_block+="# @endactive"

  # Replace the @active...@endactive block in the file
  local tmpfile
  tmpfile=$(mktemp)
  local skipping="no"
  while IFS= read -r line; do
    if [[ "$line" =~ ^#\ @active ]]; then
      echo "$active_block" >> "$tmpfile"
      skipping="yes"
      continue
    fi
    if [[ "$skipping" == "yes" ]]; then
      [[ "$line" == "# @endactive" ]] && skipping="no"
      continue
    fi
    echo "$line" >> "$tmpfile"
  done < "$ENV_FILE"
  mv "$tmpfile" "$ENV_FILE"

  # Print summary
  echo ""
  echo "Switched to: $target_name ($target_id)"
  if [[ -n "${C_ENVS[$idx]}" ]]; then
    while IFS= read -r env_line; do
      [[ -z "$env_line" ]] && continue
      local key="${env_line%%=*}"
      local val="${env_line#*=}"
      printf "  %-14s %s\n" "$key:" "$val"
    done <<< "${C_ENVS[$idx]}"
  fi
  printf "  %-14s %s\n" "OC_USER:" "$sel_user"

  if [[ -n "${C_URLS[$idx]}" ]]; then
    while IFS= read -r url_line; do
      [[ -z "$url_line" ]] && continue
      local label="${url_line%% *}"
      local url="${url_line#* }"
      printf "  %-14s %s\n" "$label:" "$url"
    done <<< "${C_URLS[$idx]}"
  fi
  echo ""
}

do_login() {
  echo "Logging in..."
  (cd "$ODH_DIR" && make login) || die "login failed — are you on the VPN?"
  echo ""
  oc cluster-info 2>/dev/null | head -1
  echo "Logged in as: $(oc whoami 2>/dev/null)"
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

DO_LOGIN="yes"
POSITIONAL=()

while [[ $# -gt 0 ]]; do
  case $1 in
    --no-login) DO_LOGIN="no"; shift ;;
    --help|-h)
      echo "Usage: odh-env [--no-login] [<cluster-id> [<username>]]"
      echo ""
      echo "  odh-env                  List clusters and show active"
      echo "  odh-env <id>             Switch to cluster (prompts for user if multiple)"
      echo "  odh-env <id> <user>      Switch to cluster with specific user"
      echo "  odh-env --no-login <id>  Switch without running make login"
      exit 0
      ;;
    -*) die "unknown flag: $1" ;;
    *) POSITIONAL+=("$1"); shift ;;
  esac
done

parse_clusters

if [[ ${#POSITIONAL[@]} -eq 0 ]]; then
  list_clusters
else
  switch_cluster "${POSITIONAL[0]}" "${POSITIONAL[1]:-}"
  if [[ "$DO_LOGIN" == "yes" ]]; then
    do_login
  fi
fi
