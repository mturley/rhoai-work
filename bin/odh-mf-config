#!/usr/bin/env bash
# Reads workspace module-federation configs and outputs JSON with optional port overrides.
# Used to set MODULE_FEDERATION_CONFIG env var so the backend proxies to the right ports.
#
# Usage:
#   odh-mf-config                          # Output all configs unchanged
#   odh-mf-config modelRegistry=4022       # Override modelRegistry's local port to 4022
#   odh-mf-config modelRegistry=4022 genAi=4024  # Override multiple modules
#
# Reads WORKTREE_PORTS from env but does NOT automatically apply offsets.
# Port overrides must be passed explicitly as arguments.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/_functions.sh"

# Collect port overrides from arguments into a JSON object: {"modelRegistry": 4022, ...}
OVERRIDES="{}"
for arg in "$@"; do
  if [[ "$arg" == *=* ]]; then
    name="${arg%%=*}"
    port="${arg#*=}"
    OVERRIDES=$(echo "$OVERRIDES" | node -e "
      const o = JSON.parse(require('fs').readFileSync('/dev/stdin','utf8'));
      o['$name'] = $port;
      process.stdout.write(JSON.stringify(o));
    ")
  fi
done

# Read workspace MF configs and apply overrides
cd "$(git rev-parse --show-toplevel 2>/dev/null || echo "$ODH_DASHBOARD")" || exit 1

npm query .workspace --json 2>/dev/null | node -e "
const overrides = $OVERRIDES;
const pkgs = JSON.parse(require('fs').readFileSync('/dev/stdin', 'utf8'));
const configs = pkgs
  .map(p => p['module-federation'])
  .filter(Boolean)
  .map(config => {
    const port = overrides[config.name];
    if (port == null) return config;

    // Deep clone to avoid mutation
    const c = JSON.parse(JSON.stringify(config));

    // Old format: has top-level 'local' and 'remoteEntry'
    if ('remoteEntry' in c) {
      if (c.local) c.local.port = port;
      else c.local = { host: 'localhost', port };
      return c;
    }

    // New format: has 'backend' and/or 'proxyService'
    if (c.backend?.localService) {
      c.backend.localService.port = port;
    } else if (c.backend) {
      c.backend.localService = { host: 'localhost', port };
    }
    if (c.proxyService) {
      for (const ps of c.proxyService) {
        if (ps.localService) ps.localService.port = port;
        else ps.localService = { host: 'localhost', port };
      }
    }
    return c;
  });

process.stdout.write(JSON.stringify(configs));
"
