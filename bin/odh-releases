#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
WORKSPACE="$(dirname "$SCRIPT_DIR")"
ODH_DIR="$WORKSPACE/opendatahub-io/odh-dashboard"

[[ -d "$ODH_DIR/.git" ]] || { echo "error: odh-dashboard clone not found at $ODH_DIR" >&2; exit 1; }

LIMIT="${1:-10}"
cd "$ODH_DIR"
git tag -l 'v*' --sort=-version:refname | head -"$LIMIT" | while read -r tag; do
  date=$(git log -1 --format='%ci' "$tag" 2>/dev/null | cut -d' ' -f1,2)
  printf "%-20s %s\n" "$tag" "$date"
done
