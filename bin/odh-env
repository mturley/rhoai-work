#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
WORKSPACE="$(dirname "$SCRIPT_DIR")"

if git remote -v 2>/dev/null | grep -q "odh-dashboard"; then
  ODH_DIR="$(git rev-parse --show-toplevel)"
else
  ODH_DIR="$WORKSPACE/opendatahub-io/odh-dashboard"
fi
ENV_FILE="$ODH_DIR/.env.local"

die() { echo "error: $*" >&2; exit 1; }

# ---------------------------------------------------------------------------
# Isolated KUBECONFIG support
# ---------------------------------------------------------------------------
is_in_worktree() {
  [[ -f "$ODH_DIR/.git" ]]
}

worktree_kubeconfig_path() {
  local wt_name
  wt_name="$(basename "$ODH_DIR")"
  echo "$HOME/.kube/config-$wt_name"
}

write_kubeconfig_line() {
  local tmpfile
  tmpfile=$(mktemp)
  local last_impersonate_line=0 line_num=0

  # Find the last DEV_IMPERSONATE_ line (commented or not)
  while IFS= read -r line; do
    line_num=$((line_num + 1))
    if [[ "$line" =~ DEV_IMPERSONATE_ ]]; then
      last_impersonate_line=$line_num
    fi
  done < "$ENV_FILE"

  # Rewrite: strip existing KUBECONFIG line, insert new one after impersonate vars
  line_num=0
  while IFS= read -r line; do
    line_num=$((line_num + 1))
    [[ "$line" =~ ^(export[[:space:]]+)?KUBECONFIG= ]] && continue
    echo "$line" >> "$tmpfile"
    if [[ $line_num -eq $last_impersonate_line && "$ISOLATE" == "yes" ]]; then
      echo "KUBECONFIG=$(worktree_kubeconfig_path)" >> "$tmpfile"
    fi
  done < "$ENV_FILE"
  mv "$tmpfile" "$ENV_FILE"
}

# Run a command, retrying on failure with a prompt to let the user fix things (e.g. VPN)
retry_loop() {
  local description=$1
  shift
  while true; do
    if "$@" 2>&1; then
      return 0
    fi
    echo ""
    echo "$description failed."
    printf "Press Enter to retry (or Ctrl-C to abort)... "
    read -r
  done
}

[[ -f "$ENV_FILE" ]] || die ".env.local not found at $ENV_FILE"

# ---------------------------------------------------------------------------
# Type -> project/app mapping
# ---------------------------------------------------------------------------
project_for_type() {
  case $1 in
    odh)   echo "opendatahub" ;;
    rhoai) echo "redhat-ods-applications" ;;
    *)     die "unknown cluster type '$1'" ;;
  esac
}

app_for_type() {
  case $1 in
    odh)   echo "odh-dashboard" ;;
    rhoai) echo "rhods-dashboard" ;;
    *)     die "unknown cluster type '$1'" ;;
  esac
}

# ---------------------------------------------------------------------------
# Parse cluster definitions from # @cluster ... # @endcluster blocks
# Parallel arrays indexed the same way. Multi-value fields use $'\n' delimiter.
# ---------------------------------------------------------------------------
C_IDS=()
C_NAMES=()
C_TYPES=()
C_USERS=()      # newline-delimited usernames
C_PASSWORDS=()  # newline-delimited passwords (parallel to C_USERS)
C_ENVS=()       # newline-delimited KEY=value lines
C_URLS=()       # newline-delimited "LABEL url" lines

parse_clusters() {
  local cur_id="" cur_name="" cur_type=""
  local users="" passwords="" envs="" urls=""

  while IFS= read -r line; do
    if [[ "$line" =~ ^#\ @cluster\ id=([^ ]+)\ name=\"([^\"]+)\"\ type=([^ ]+) ]]; then
      cur_id="${BASH_REMATCH[1]}"
      cur_name="${BASH_REMATCH[2]}"
      cur_type="${BASH_REMATCH[3]}"
      users="" passwords="" envs="" urls=""
    elif [[ "$line" == "# @endcluster" && -n "$cur_id" ]]; then
      C_IDS+=("$cur_id")
      C_NAMES+=("$cur_name")
      C_TYPES+=("$cur_type")
      C_USERS+=("$users")
      C_PASSWORDS+=("$passwords")
      C_ENVS+=("$envs")
      C_URLS+=("$urls")
      cur_id=""
    elif [[ -n "$cur_id" ]]; then
      if [[ "$line" =~ ^#\ @user\ (.+) ]]; then
        local rest="${BASH_REMATCH[1]}"
        local u p
        u="${rest%% *}"
        if [[ "$rest" == *" "* ]]; then
          p="${rest#* }"
          p="${p//\\#/#}"  # unescape \# from storage format
        else
          echo "error: cluster '$cur_id' has @user '$u' with no password" >&2
          exit 1
        fi
        users+="${users:+$'\n'}$u"
        passwords+="${passwords:+$'\n'}$p"
      elif [[ "$line" =~ ^#\ @env\ (.+) ]]; then
        envs+="${envs:+$'\n'}${BASH_REMATCH[1]}"
      elif [[ "$line" =~ ^#\ @url\ (.+) ]]; then
        urls+="${urls:+$'\n'}${BASH_REMATCH[1]}"
      fi
    fi
  done < "$ENV_FILE"
}

find_cluster_idx() {
  local target=$1
  for i in "${!C_IDS[@]}"; do
    if [[ "${C_IDS[$i]}" == "$target" ]]; then
      echo "$i"
      return
    fi
  done
}

get_active_id() {
  local line
  line=$(grep '^# @active' "$ENV_FILE" 2>/dev/null | head -1) || true
  if [[ "$line" =~ ^#\ @active\ id=([^ ]+) ]]; then
    echo "${BASH_REMATCH[1]}"
  fi
}

# ---------------------------------------------------------------------------
# Actions
# ---------------------------------------------------------------------------

list_clusters() {
  local active_id
  active_id=$(get_active_id)
  printf "%-14s %-35s %-6s %s\n" "ID" "NAME" "TYPE" "STATUS"
  printf "%-14s %-35s %-6s %s\n" "--" "----" "----" "------"
  for i in "${!C_IDS[@]}"; do
    local id="${C_IDS[$i]}"
    local status=""
    [[ "$id" == "$active_id" ]] && status="* active"
    printf "%-14s %-35s %-6s %s\n" "$id" "${C_NAMES[$i]}" "${C_TYPES[$i]}" "$status"
  done
}

# Build and write the @active block for a given cluster index + selected user/pass
write_active_block() {
  local idx=$1 sel_user=$2 sel_pass=$3
  local target_id="${C_IDS[$idx]}"
  local cluster_type="${C_TYPES[$idx]}"

  local active_block=""
  active_block+="# @active id=$target_id"$'\n'
  if [[ -n "${C_ENVS[$idx]}" ]]; then
    while IFS= read -r env_line; do
      [[ -n "$env_line" ]] && active_block+="$env_line"$'\n'
    done <<< "${C_ENVS[$idx]}"
  fi
  active_block+="OC_PROJECT=$(project_for_type "$cluster_type")"$'\n'
  active_block+="ODH_APP=$(app_for_type "$cluster_type")"$'\n'
  active_block+="OC_USER=$sel_user"$'\n'
  [[ -n "$sel_pass" ]] && active_block+="OC_PASSWORD=${sel_pass//#/\\#}"$'\n'
  active_block+="# @endactive"

  local tmpfile
  tmpfile=$(mktemp)
  local skipping="no"
  while IFS= read -r line; do
    if [[ "$line" =~ ^#\ @active ]]; then
      echo "$active_block" >> "$tmpfile"
      skipping="yes"
      continue
    fi
    if [[ "$skipping" == "yes" ]]; then
      [[ "$line" == "# @endactive" ]] && skipping="no"
      continue
    fi
    echo "$line" >> "$tmpfile"
  done < "$ENV_FILE"
  mv "$tmpfile" "$ENV_FILE"
}

print_summary() {
  local idx=$1 sel_user=$2
  local cluster_type="${C_TYPES[$idx]}"

  echo ""
  echo "Switched to: ${C_NAMES[$idx]} (${C_IDS[$idx]}, $cluster_type)"
  if [[ -n "${C_ENVS[$idx]}" ]]; then
    while IFS= read -r env_line; do
      [[ -z "$env_line" ]] && continue
      local key="${env_line%%=*}"
      local val="${env_line#*=}"
      printf "  %-14s %s\n" "$key:" "$val"
    done <<< "${C_ENVS[$idx]}"
  fi
  printf "  %-14s %s\n" "OC_PROJECT:" "$(project_for_type "$cluster_type")"
  printf "  %-14s %s\n" "ODH_APP:" "$(app_for_type "$cluster_type")"
  printf "  %-14s %s\n" "OC_USER:" "$sel_user"
  if [[ "$ISOLATE" == "yes" ]]; then
    printf "  %-14s %s\n" "KUBECONFIG:" "$(worktree_kubeconfig_path)"
  fi

  if [[ -n "${C_URLS[$idx]}" ]]; then
    while IFS= read -r url_line; do
      [[ -z "$url_line" ]] && continue
      local label="${url_line%% *}"
      local url="${url_line#* }"
      printf "  %-14s %s\n" "$label:" "$url"
    done <<< "${C_URLS[$idx]}"
  fi
  echo ""
}

select_user() {
  local idx=$1 target_user=${2:-}
  local target_id="${C_IDS[$idx]}"
  local target_name="${C_NAMES[$idx]}"

  local -a users=() passwords=()
  if [[ -n "${C_USERS[$idx]}" ]]; then
    while IFS= read -r u; do users+=("$u"); done <<< "${C_USERS[$idx]}"
    while IFS= read -r p; do passwords+=("$p"); done <<< "${C_PASSWORDS[$idx]}"
  fi

  [[ ${#users[@]} -gt 0 ]] || die "cluster '$target_id' has no @user lines"

  local selected_idx=0
  if [[ -n "$target_user" ]]; then
    local found=false
    for i in "${!users[@]}"; do
      if [[ "${users[$i]}" == "$target_user" ]]; then
        selected_idx=$i; found=true; break
      fi
    done
    $found || die "user '$target_user' not found for cluster '$target_id'. Available: ${users[*]}"
  elif [[ ${#users[@]} -gt 1 ]]; then
    echo "Select user for $target_name:"
    for i in "${!users[@]}"; do
      local marker=""
      [[ $i -eq 0 ]] && marker=" (default)"
      echo "  $((i + 1))) ${users[$i]}$marker"
    done
    printf "Choice [1]: "
    read -r choice
    choice=${choice:-1}
    if [[ "$choice" -ge 1 && "$choice" -le ${#users[@]} ]] 2>/dev/null; then
      selected_idx=$((choice - 1))
    else
      die "invalid choice"
    fi
  fi

  SEL_USER="${users[$selected_idx]}"
  SEL_PASS="${passwords[$selected_idx]}"
}

switch_cluster() {
  local target_id=$1
  local target_user=${2:-}

  local idx
  idx=$(find_cluster_idx "$target_id")
  [[ -n "$idx" ]] || die "unknown cluster '$target_id'. Run 'odh-env' to list available clusters."

  select_user "$idx" "$target_user"
  write_active_block "$idx" "$SEL_USER" "$SEL_PASS"
  write_kubeconfig_line
  print_summary "$idx" "$SEL_USER"
}

do_login() {
  echo "Logging in..."
  retry_loop "Login" bash -c "cd '$ODH_DIR' && make login"
  echo ""
  oc cluster-info 2>/dev/null | head -1
  echo "Logged in as: $(oc whoami 2>/dev/null)"
}

# ---------------------------------------------------------------------------
# --add-cluster
# ---------------------------------------------------------------------------

add_cluster() {
  # Prompt for cluster details
  printf "Cluster ID (short kebab-case slug): "
  read -r new_id
  [[ -n "$new_id" ]] || die "cluster ID is required"
  local existing
  existing=$(find_cluster_idx "$new_id")
  [[ -z "$existing" ]] || die "cluster '$new_id' already exists"

  printf "Cluster name (display name): "
  read -r new_name
  [[ -n "$new_name" ]] || die "cluster name is required"

  printf "OC_URL (API server URL, e.g. https://api.example.com:6443): "
  read -r new_url
  [[ -n "$new_url" ]] || die "OC_URL is required"

  echo "Cluster type:"
  echo "  1) ODH (OC_PROJECT=opendatahub, ODH_APP=odh-dashboard)"
  echo "  2) RHOAI (OC_PROJECT=redhat-ods-applications, ODH_APP=rhods-dashboard)"
  printf "Choice [1]: "
  read -r type_choice
  type_choice=${type_choice:-1}
  local new_type
  case $type_choice in
    1) new_type="odh" ;;
    2) new_type="rhoai" ;;
    *) die "invalid choice" ;;
  esac

  printf "Username: "
  read -r new_user
  [[ -n "$new_user" ]] || die "username is required"

  printf "Password: "
  read -rs new_pass
  echo ""
  [[ -n "$new_pass" ]] || die "password is required"

  # Log in to discover routes
  echo ""
  echo "Logging in to discover routes..."
  retry_loop "Login" oc login "$new_url" -u "$new_user" -p "$new_pass" --insecure-skip-tls-verify=true

  # Discover OCP console URL
  local ocp_host
  ocp_host=$(oc get route console -n openshift-console -o jsonpath='{.spec.host}' 2>/dev/null) || true
  local ocp_url=""
  [[ -n "$ocp_host" ]] && ocp_url="https://$ocp_host/"

  # Discover dashboard URL
  # Try the gateway route in openshift-ingress first (gives the rh-ai.* redirect URL)
  local dash_host dash_label
  dash_host=$(oc get route data-science-gateway -n openshift-ingress -o jsonpath='{.spec.host}' 2>/dev/null) || true

  if [[ -n "$dash_host" ]]; then
    dash_label=$(echo "$new_type" | tr '[:lower:]' '[:upper:]')
  else
    # Fall back to the dashboard route in the project namespace
    local project route_name
    project=$(project_for_type "$new_type")
    route_name=$(app_for_type "$new_type")
    dash_host=$(oc get route "$route_name" -n "$project" -o jsonpath='{.spec.host}' 2>/dev/null) || true
    dash_label=$(echo "$new_type" | tr '[:lower:]' '[:upper:]')
  fi
  local dash_url=""
  [[ -n "$dash_host" ]] && dash_url="https://$dash_host/"

  # Escape # in passwords so they survive Make's `include` (which treats # as comment)
  local escaped_pass="${new_pass//#/\\#}"

  # Build the cluster definition block
  local block=""
  block+="# @cluster id=$new_id name=\"$new_name\" type=$new_type"$'\n'
  [[ -n "$ocp_url" ]] && block+="# @url OCP $ocp_url"$'\n'
  [[ -n "$dash_url" ]] && block+="# @url $dash_label $dash_url"$'\n'
  block+="# @user $new_user $escaped_pass"$'\n'
  block+="# @env OC_URL=$new_url"$'\n'
  block+="# @endcluster"

  # Append before the Global Settings separator
  local tmpfile
  tmpfile=$(mktemp)
  local inserted="no"
  while IFS= read -r line; do
    if [[ "$inserted" == "no" && "$line" == "# ---------------------------------------------------------------------------" ]]; then
      # Check if the next context is "Global Settings" by peeking — but we can't
      # easily peek in bash. Instead, check if we've already passed all @endcluster lines.
      # Simpler: insert before the LAST separator block. We'll use a different approach:
      # just append after the last @endcluster line.
      :
    fi
    echo "$line" >> "$tmpfile"
  done < "$ENV_FILE"

  # Simpler approach: find the last @endcluster and insert after it
  local last_endcluster_line
  last_endcluster_line=$(grep -n '^# @endcluster' "$ENV_FILE" | tail -1 | cut -d: -f1)
  [[ -n "$last_endcluster_line" ]] || die "no existing cluster definitions found in .env.local"

  rm -f "$tmpfile"
  tmpfile=$(mktemp)
  local line_num=0
  while IFS= read -r line; do
    line_num=$((line_num + 1))
    echo "$line" >> "$tmpfile"
    if [[ $line_num -eq $last_endcluster_line ]]; then
      echo "" >> "$tmpfile"
      echo "$block" >> "$tmpfile"
    fi
  done < "$ENV_FILE"
  mv "$tmpfile" "$ENV_FILE"

  echo ""
  echo "Added cluster: $new_name ($new_id, $new_type)"
  [[ -n "$ocp_url" ]] && echo "  OCP:  $ocp_url"
  [[ -n "$dash_url" ]] && echo "  $dash_label:  $dash_url"
  echo ""

  # Re-parse and switch to the new cluster
  parse_clusters
  local new_idx
  new_idx=$(find_cluster_idx "$new_id")
  [[ -n "$new_idx" ]] || die "failed to find newly added cluster '$new_id'"

  # We already know the user/pass — write active block directly
  write_active_block "$new_idx" "$new_user" "$new_pass"
  write_kubeconfig_line
  print_summary "$new_idx" "$new_user"

  # Already logged in from discovery step, just verify
  echo "Already logged in."
  oc cluster-info 2>/dev/null | head -1
  echo "Logged in as: $(oc whoami 2>/dev/null)"
  echo ""
  echo "Modified: ${ENV_FILE/#$HOME/~}"
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

INCOMING_KUBECONFIG="${KUBECONFIG:-}"

DO_LOGIN="yes"
ADD_CLUSTER="no"
ISOLATE=""  # empty = auto-detect
POSITIONAL=()

while [[ $# -gt 0 ]]; do
  case $1 in
    --no-login) DO_LOGIN="no"; shift ;;
    --add-cluster) ADD_CLUSTER="yes"; shift ;;
    --isolated) ISOLATE="yes"; shift ;;
    --no-isolated) ISOLATE="no"; shift ;;
    --help|-h)
      echo "Usage: odh-env [--no-login] [--isolated|--no-isolated] [<cluster-id> [<username>]]"
      echo "       odh-env --add-cluster"
      echo ""
      echo "  odh-env                  List clusters and show active"
      echo "  odh-env <id>             Switch to cluster (prompts for user if multiple)"
      echo "  odh-env <id> <user>      Switch to cluster with specific user"
      echo "  odh-env --no-login <id>  Switch without running make login"
      echo "  odh-env --add-cluster    Add a new cluster interactively"
      echo ""
      echo "  --isolated               Use a per-worktree kubeconfig (default in worktrees)"
      echo "  --no-isolated            Use the shared ~/.kube/config even in a worktree"
      exit 0
      ;;
    -*) die "unknown flag: $1" ;;
    *) POSITIONAL+=("$1"); shift ;;
  esac
done

# Resolve isolation: auto-detect from worktree if not explicitly set
if [[ -z "$ISOLATE" ]]; then
  if is_in_worktree; then
    ISOLATE="yes"
  else
    ISOLATE="no"
  fi
fi

if [[ "$ISOLATE" == "yes" ]]; then
  export KUBECONFIG="$(worktree_kubeconfig_path)"
fi

parse_clusters

if [[ "$ADD_CLUSTER" == "yes" ]]; then
  add_cluster
elif [[ ${#POSITIONAL[@]} -eq 0 ]]; then
  list_clusters
else
  switch_cluster "${POSITIONAL[0]}" "${POSITIONAL[1]:-}"
  if [[ "$DO_LOGIN" == "yes" ]]; then
    do_login
  fi
  echo ""
  echo "Modified: ${ENV_FILE/#$HOME/~}"
  if [[ "$ISOLATE" == "yes" ]]; then
    expected_kc="$(worktree_kubeconfig_path)"
    if [[ "$INCOMING_KUBECONFIG" == "$expected_kc" ]]; then
      echo "KUBECONFIG already points to ${expected_kc/#$HOME/~} in this shell."
      echo "oc commands in this worktree will use this cluster."
    else
      echo "To use this config in your shell, run:"
      echo "  export KUBECONFIG=${expected_kc/#$HOME/~}"
    fi
  fi
fi
