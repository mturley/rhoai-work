#!/usr/bin/env bash
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Resolve mprocs-motd.sh from the work-scripts repo (via worktree on PATH)
WORKTREE_BIN="$(command -v worktree 2>/dev/null || true)"
if [ -n "$WORKTREE_BIN" ]; then
  MPROCS_MOTD="$(cd "$(dirname "$(readlink -f "$WORKTREE_BIN")")/../../lib" && pwd)/mprocs-motd.sh"
fi

USE_ITERM=false
USE_DEFAULT_PORTS=false
USE_DEFAULT_TITLE=false
USE_SHELL=true
TITLE=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --iterm)
      USE_ITERM=true
      shift
      ;;
    --no-shell)
      USE_SHELL=false
      shift
      ;;
    --title=*)
      TITLE="${1#--title=}"
      shift
      ;;
    --title)
      TITLE="$2"
      shift 2
      ;;
    --default-ports)
      USE_DEFAULT_PORTS=true
      shift
      ;;
    --default-title)
      USE_DEFAULT_TITLE=true
      shift
      ;;
    *)
      shift
      ;;
  esac
done

# Use WORKTREE_TITLE as fallback title if --title was not passed
if [[ "$USE_DEFAULT_TITLE" != true && -z "$TITLE" && -n "${WORKTREE_TITLE:-}" ]]; then
  TITLE="$WORKTREE_TITLE"
fi

# Port range: use WORKTREE_PORTS env var if set, otherwise use default ports
if [[ "$USE_DEFAULT_PORTS" == true ]] || [[ -z "${WORKTREE_PORTS:-}" ]]; then
  unset WORKTREE_PORTS
  BACKEND_PORT_LABEL="4000"
  FRONTEND_PORT_LABEL="4010"
  MR_PORT_LABEL="9100"
else
  export WORKTREE_PORTS
  RANGE_START="${WORKTREE_PORTS%%-*}"
  BACKEND_PORT_LABEL="$RANGE_START"
  FRONTEND_PORT_LABEL="$((RANGE_START + 1))"
  MR_PORT_LABEL="$((RANGE_START + 2))"
  echo "Dashboard: http://localhost:${FRONTEND_PORT_LABEL}"
fi

# --- Dev processes (comment out lines here to skip them) ---
DEV_NAMES=()
DEV_CMDS=()
DEV_NAMES+=("frontend:${FRONTEND_PORT_LABEL}");  DEV_CMDS+=("$SCRIPT_DIR/odh-dev-frontend")
DEV_NAMES+=("backend:${BACKEND_PORT_LABEL}");    DEV_CMDS+=("$SCRIPT_DIR/odh-dev-backend")
DEV_NAMES+=("mr-upstream:${MR_PORT_LABEL}");     DEV_CMDS+=("$SCRIPT_DIR/odh-dev-mr-upstream-federated")

DEV_NAMES_CSV="$(IFS=,; echo "${DEV_NAMES[*]}")"

if [[ "$USE_ITERM" == true ]]; then
  for cmd in "${DEV_CMDS[@]}"; do
    iterm-new split-v "$(basename "$cmd")"
  done
else
  MPROCS_ARGS=()
  [[ -n "$TITLE" ]] && MPROCS_ARGS+=(--proc-list-title "$TITLE")

  # Detect if we're in a git worktree (not the main worktree)
  IN_WORKTREE=false
  if git rev-parse --is-inside-work-tree &>/dev/null; then
    WT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
    if [ -n "$WT_ROOT" ] && [ -f "$WT_ROOT/.git" ]; then
      IN_WORKTREE=true
    fi
  fi

  # If inside a worktree shell-command mprocs, add dev panes to it
  if [[ -n "${WORKTREE_SHELL_MPROCS_SOCK:-}" ]]; then
    SHELL_MPROCS_COUNT="/tmp/worktree-shell-mprocs-${WORKTREE_SHELL_MPROCS_PID:-unknown}-count"
    if [ ! -f "$SHELL_MPROCS_COUNT" ]; then
      echo 2 > "$SHELL_MPROCS_COUNT"
    fi
    for i in "${!DEV_NAMES[@]}"; do
      mprocs --server="$WORKTREE_SHELL_MPROCS_SOCK" --ctl="{c: add-proc, cmd: \"cd '$PWD' && WORKTREE_PORTS='${WORKTREE_PORTS:-}' ${DEV_CMDS[$i]}\", name: \"${DEV_NAMES[$i]}\"}"
      CURRENT="$(cat "$SHELL_MPROCS_COUNT")"
      echo "$((CURRENT + 1))" > "$SHELL_MPROCS_COUNT"
    done
    echo "Added ${#DEV_NAMES[@]} dev panes to worktree mprocs session."
  elif [[ -n "${CMUX_SOCKET_PATH:-}" ]]; then
    # Inside cmux: skip worktree/shell panes, cmux provides its own terminals
    MPROCS_ARGS+=(--names "$DEV_NAMES_CSV")
    mprocs "${MPROCS_ARGS[@]}" "${DEV_CMDS[@]}"
  elif [[ "$USE_SHELL" == true ]]; then
    SHELL_LABEL="[$(basename "$SHELL")]"
    SHELL_CMD="$SHELL"
    if [ -n "${MPROCS_MOTD:-}" ] && [ -x "$MPROCS_MOTD" ]; then
      SHELL_CMD="$MPROCS_MOTD && exec $SHELL"
    fi
    if [[ "$IN_WORKTREE" == true ]]; then
      MPROCS_ARGS+=(--names "[worktree],$SHELL_LABEL,$DEV_NAMES_CSV")
      mprocs "${MPROCS_ARGS[@]}" "worktree" "$SHELL_CMD" "${DEV_CMDS[@]}"
    else
      MPROCS_ARGS+=(--names "$SHELL_LABEL,$DEV_NAMES_CSV")
      mprocs "${MPROCS_ARGS[@]}" "$SHELL_CMD" "${DEV_CMDS[@]}"
    fi
  else
    MPROCS_ARGS+=(--names "$DEV_NAMES_CSV")
    mprocs "${MPROCS_ARGS[@]}" "${DEV_CMDS[@]}"
  fi
fi
